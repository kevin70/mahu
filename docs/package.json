{
  "name": "mahu-docs",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "openapi-admin": "redocly bundle admin@v1 -o src/public/mahu-admin-openapi.yaml && redocly build-docs admin@v1 -o src/public/mahu-admin-openapi.html",
    "openapi": "pnpm openapi-admin",
    "docs:dev": "vitepress dev",
    "docs:build": "pnpm openapi && vitepress build",
    "docs:preview": "vitepress preview"
  },
  "devDependencies": {
    "@braintree/sanitize-url": "^7.1.1",
    "@mdit/plugin-embed": "^0.22.1",
    "@mdit/plugin-icon": "^0.22.1",
    "@mdit/plugin-mark": "^0.22.1",
    "@mdit/plugin-tasklist": "^0.22.1",
    "@redocly/cli": "^2.0.7",
    "cytoscape": "^3.33.1",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dayjs": "^1.11.13",
    "debug": "^4.4.1",
    "markdown-it": "^14.1.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-diagrams": "^1.0.0",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}