{
  "name": "mahu-admin-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "gen:oas": "redocly bundle ../../openapi/admin/openapi.yaml -o dist/openapi.yaml && openapi-generator-cli generate -g typescript-fetch -o src/services/generated -i dist/openapi.yaml --additional-properties=useSingleRequestParameter=false"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "@ant-design/pro-components": "^2.8.1",
    "@tanstack/react-query": "^5.59.15",
    "ahooks": "^3.8.1",
    "antd": "^5.21.4",
    "axios": "^1.7.7",
    "dayjs": "^1.11.13",
    "lodash-es": "^4.17.21",
    "rc-resize-observer": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^6.27.0",
    "react-router-dom": "^6.27.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@emotion/babel-plugin": "^11.12.0",
    "@emotion/react": "^11.13.3",
    "@eslint/js": "^9.13.0",
    "@openapitools/openapi-generator-cli": "^2.14.0",
    "@redocly/cli": "^1.25.7",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "5.1.0-rc-fb9a90fa48-20240614",
    "eslint-plugin-react-refresh": "^0.4.13",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.9",
    "vite-tsconfig-paths": "^5.0.1"
  }
}
